# ============================================================================
# Supabase Edge Functions — secrets
# Copy this file to `supabase/.env` and fill in the values.
# `supabase/.env` is gitignored — NEVER commit real secrets.
# ============================================================================

# --- Required by all functions (auto-set by Supabase CLI in production) ---
# Your project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# The service_role key (Project Settings → API → service_role secret).
# Used by functions to bypass RLS. NEVER expose this in the client app.
SUPABASE_SERVICE_ROLE_KEY=
# Your project's JWT secret (Project Settings → API → JWT Secret).
JWT_SECRET=

# ============================================================================
# Used by the ADMIN DASHBOARD (separate file: admin/.env)
# These are the *anon* public key (safe to ship) + the URL.
# ============================================================================
# SUPABASE_URL=https://abcdefgh.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
