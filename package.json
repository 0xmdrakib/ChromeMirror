{
  "name": "chrome-mirror",
  "version": "2.0.0",
  "description": "Mirror one Chrome profile to up to 24 follower profiles with an optional hosted licensing service.",
  "main": "src/main/main.js",
  "author": "Md. Rakib",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "lint": "npm run lint:desktop && npm --prefix web run lint",
    "lint:desktop": "node scripts/check-desktop.js",
    "typecheck": "npm --prefix web run typecheck",
    "test": "node --test tests/*.test.js",
    "test:web": "npm --prefix web test",
    "test:all": "npm test && npm run test:web",
    "scan:secrets": "node scripts/check-secrets.js",
    "prebuild": "npx electron scripts/compile.js",
    "build:web": "npm --prefix web run build",
    "pack": "npm run prebuild && electron-builder --dir",
    "dist": "npm run prebuild && electron-builder --publish never",
    "verify": "npm run scan:secrets && npm run lint && npm run typecheck && npm run test:all && npm run prebuild && npm run build:web"
  },
  "build": {
    "appId": "com.rakib.chromemirror",
    "productName": "Chrome Mirror",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Chrome-Mirror-${version}-${os}-${arch}.${ext}",
    "files": [
      "build-app/**/*",
      "package.json",
      "node_modules/playwright-core/**/*",
      "node_modules/bytenode/**/*",
      "build/icon.ico"
    ],
    "extraMetadata": {
      "main": "build-app/main/main-loader.js"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Chrome Mirror"
    },
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    }
  },
  "dependencies": {
    "bytenode": "^1.6.0",
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "javascript-obfuscator": "^4.1.1"
  },
  "overrides": {
    "undici": "7.28.0"
  }
}
